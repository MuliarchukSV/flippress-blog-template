---
import blogConfig from '../../blog.config.ts';

const product = blogConfig.product;
---

{product && (
  <aside class="product-cta not-prose my-10 rounded-2xl border border-gray-200 bg-gray-50 px-6 py-6">
    <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-1">Sponsored by the publisher</p>
    <p class="text-lg font-bold text-gray-900 mb-1">{product.name}</p>
    <p class="text-sm text-gray-600 mb-4">{product.description}</p>
    <a
      href={product.url}
      target="_blank"
      rel="noopener"
      class="inline-block rounded-lg bg-[var(--color-primary,#6366f1)] px-5 py-2 text-sm font-semibold text-white hover:opacity-90 transition"
    >
      {product.ctaText} &rarr;
    </a>
  </aside>
)}
