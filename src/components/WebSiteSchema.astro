---
import blogConfig from '../../blog.config.ts';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: blogConfig.name,
  url: blogConfig.site,
  description: blogConfig.description,
  publisher: {
    "@type": "Organization",
    name: "FlipFactory",
    url: "https://flipfactory.it.com",
    sameAs: blogConfig.author.sameAs,
  },
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: `${blogConfig.site}/blog/?q={search_term_string}`,
    },
    "query-input": "required name=search_term_string",
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
