---
import blogConfig from '../../blog.config.ts';

interface Props {
  title: string;
  slug: string;
}

const { title, slug } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: blogConfig.name,
      item: blogConfig.site,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Blog",
      item: `${blogConfig.site}/blog/`,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: title,
      item: `${blogConfig.site}/blog/${slug}/`,
    },
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
