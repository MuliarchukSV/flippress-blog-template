---
import blogConfig from '../../blog.config.ts';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  url: string;
}

const { title, description, pubDate, updatedDate, author = "FlipFactory Editorial Team", url } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate || pubDate).toISOString(),
  url,
  author: {
    "@type": "Organization",
    name: author,
    url: "https://flipfactory.it.com",
  },
  publisher: {
    "@type": "Organization",
    name: "FlipPress",
    url: "https://flipfactory.it.com/flippress",
    parentOrganization: {
      "@type": "Organization",
      name: "FlipFactory",
    },
  },
  isAccessibleForFree: true,
  inLanguage: blogConfig.language,
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
