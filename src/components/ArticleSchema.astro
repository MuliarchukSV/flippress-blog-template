---
import blogConfig from '../../blog.config.ts';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  url: string;
  tags?: string[];
  image?: string;
  wordCount?: number;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  author = blogConfig.author?.name ?? 'FlipFactory Editorial Team',
  url,
  tags = [],
  image,
  wordCount,
} = Astro.props;

// Use explicit image, or auto-generate from article slug as fallback
const slugFromUrl = url.split('/blog/')[1]?.replace(/\/$/, '') ?? '';
const ogImage = image
  ? new URL(image, blogConfig.site).toString()
  : slugFromUrl
    ? new URL(`/og/${slugFromUrl}.png`, blogConfig.site).toString()
    : undefined;

const isOrgAuthor = author === (blogConfig.author?.name ?? 'FlipFactory Editorial Team');

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": url,
  },
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate || pubDate).toISOString(),
  url,
  ...(ogImage ? { image: { "@type": "ImageObject", url: ogImage, width: 1200, height: 630 } } : {}),
  ...(wordCount ? { wordCount } : {}),
  ...(tags.length > 0 ? { keywords: tags.join(", ") } : {}),
  about: {
    "@type": "Thing",
    name: blogConfig.niche,
  },
  author: isOrgAuthor
    ? {
        "@type": "Organization",
        name: author,
        url: blogConfig.author?.url ?? blogConfig.site,
        sameAs: blogConfig.author?.sameAs ?? [],
      }
    : {
        "@type": "Person",
        name: author,
        url: blogConfig.author?.url ?? blogConfig.site,
        sameAs: blogConfig.author?.sameAs ?? [],
      },
  publisher: {
    "@type": "Organization",
    name: blogConfig.name,
    url: blogConfig.site,
    parentOrganization: {
      "@type": "Organization",
      name: "FlipFactory",
      url: "https://flipfactory.it.com",
      sameAs: blogConfig.author?.sameAs ?? [],
    },
  },
  isAccessibleForFree: true,
  inLanguage: blogConfig.language,
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: [".article-summary", ".key-takeaways", ".faq-answer", "h1"],
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
