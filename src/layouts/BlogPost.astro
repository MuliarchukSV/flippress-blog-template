---
import BaseLayout from './BaseLayout.astro';
import ArticleSchema from '../components/ArticleSchema.astro';
import FAQSchema from '../components/FAQSchema.astro';
import BreadcrumbList from '../components/BreadcrumbList.astro';
import KeyTakeaways from '../components/KeyTakeaways.astro';
import ProductCTA from '../components/ProductCTA.astro';
import AIDisclosure from '../components/AIDisclosure.astro';
import RelatedPosts from '../components/RelatedPosts.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  tags?: string[];
  image?: string;
  takeaways?: string[];
  faq?: { q: string; a: string }[];
  slug: string;
}

const { title, description, pubDate, updatedDate, author, tags = [], image, takeaways = [], faq = [], slug } = Astro.props;
const articleUrl = new URL(`/blog/${slug}`, Astro.site).toString();
---

<BaseLayout title={title} description={description} image={image} article pubDate={pubDate} updatedDate={updatedDate}>
  <ArticleSchema
    title={title}
    description={description}
    pubDate={pubDate}
    updatedDate={updatedDate}
    author={author}
    url={articleUrl}
    tags={tags}
    image={image}
  />
  <FAQSchema faq={faq} />
  <BreadcrumbList title={title} slug={slug} />

  <article class="prose prose-lg max-w-none">
    <header class="mb-8">
      <h1 class="text-3xl font-bold mb-2">{title}</h1>
      <div class="text-sm text-gray-500 flex gap-4">
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </time>
        <span>{author || "FlipFactory Editorial Team"}</span>
      </div>
      {tags.length > 0 && (
        <div class="flex gap-2 mt-3 flex-wrap">
          {tags.map((tag) => (
            <a href={`/topics/${tag}`} class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded hover:bg-primary hover:text-white transition">
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <div class="article-summary not-prose mb-6 text-gray-600 text-base leading-relaxed border-l-4 border-[var(--color-primary,#6366f1)] pl-4">
      <p>{description}</p>
    </div>

    <KeyTakeaways takeaways={takeaways} />

    <div class="article-content">
      <slot />
    </div>

    <ProductCTA />

    {faq.length > 0 && (
      <section class="mt-12">
        <h2>Frequently Asked Questions</h2>
        {faq.map((item) => (
          <div class="mb-6">
            <h3>{item.q}</h3>
            <p class="faq-answer">{item.a}</p>
          </div>
        ))}
      </section>
    )}
  </article>

  <AIDisclosure />
  <RelatedPosts currentSlug={slug} tags={tags} />
</BaseLayout>
