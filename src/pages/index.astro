---
import BaseLayout from '../layouts/BaseLayout.astro';
import WebSiteSchema from '../components/WebSiteSchema.astro';
import blogConfig from '../../blog.config.ts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={(blogConfig as any).homeTitle || blogConfig.name} description={blogConfig.description}>
  <WebSiteSchema />

  <h1 class="text-3xl font-bold mb-8">{blogConfig.name}</h1>
  <p class="text-gray-600 mb-8">{blogConfig.description}</p>

  <ul class="space-y-8">
    {posts.map((post) => (
      <li class="border-b border-gray-100 pb-6">
        <a href={`/blog/${post.id.replace(/\.mdx?$/, '')}`} class="group">
          <h2 class="text-xl font-semibold group-hover:text-primary transition">{post.data.title}</h2>
          <p class="text-gray-500 text-sm mt-1">
            {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
          </p>
          <p class="text-gray-600 mt-2">{post.data.description}</p>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
